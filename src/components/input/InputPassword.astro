---
import {
  AlertCircle,
  CheckCircle,
  Lock03,
  Eye,
  EyeOff,
} from "@untitledui/icons";
---

<div class="text-field">
  <label for="password-input" class="label">
    Password <span class="required" aria-hidden="true">*</span>
  </label>

  <div class="input-wrapper">
    <div class="input-icon-left" aria-hidden="true">
      <Lock03 />
    </div>

    <input
      id="password-input"
      type="password"
      name="password"
      required
      minlength="8"
      autocomplete="new-password"
      placeholder="••••••••••••"
      class="input-base"
    />

    <button
      type="button"
      id="password-toggle"
      class="password-toggle-btn"
      aria-label="Show password"
      aria-pressed="false"
    >
      <span class="icon-eye"><Eye /></span>
      <span class="icon-eye-off"><EyeOff /></span>
    </button>
  </div>

  <div class="hint-text">
    <span class="icon-success" aria-hidden="true">
      <CheckCircle />
    </span>
    <span class="icon-error" aria-hidden="true">
      <AlertCircle />
    </span>
    <span class="hint-message">Must be at least 8 characters.</span>
  </div>
</div>

<script>
  const passwordInput = document.getElementById(
    "password-input",
  ) as HTMLInputElement;
  const toggleBtn = document.getElementById(
    "password-toggle",
  ) as HTMLButtonElement;
  const textField = document.querySelector(".text-field");

  if (passwordInput && textField && toggleBtn) {
    // Live length checking
    passwordInput.addEventListener("input", (e) => {
      const target = e.target as HTMLInputElement;
      if (target.value.length >= 8) {
        textField.classList.add("is-valid");
      } else {
        textField.classList.remove("is-valid");
      }
    });

    // Native validation triggers on blur
    passwordInput.addEventListener("blur", () => {
      if (!passwordInput.validity.valid && passwordInput.value.length > 0) {
        textField.classList.add("is-invalid");
      } else {
        textField.classList.remove("is-invalid");
      }
    });

    // Password visibility toggle logic
    toggleBtn.addEventListener("click", () => {
      const isPassword = passwordInput.type === "password";

      passwordInput.type = isPassword ? "text" : "password";
      toggleBtn.setAttribute("aria-pressed", isPassword ? "true" : "false");
      toggleBtn.setAttribute(
        "aria-label",
        isPassword ? "Hide password" : "Show password",
      );
      toggleBtn.classList.toggle("is-visible", isPassword);
    });
  }
</script>

<style>
  .text-field {
    --fg-quaternary: #98a2b3;
    --fg-success-primary: #079455;
    --fg-error-secondary: #d92d20;
    --border-primary: #d0d5dd;
    --text-primary: #101828;

    display: flex;
    flex-direction: column;
    gap: 6px;
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
  }

  .label {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
  }

  .required {
    color: var(--fg-error-secondary);
  }

  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input-base {
    width: 100%;
    /* Extra padding on the right (44px) to avoid text clashing with the toggle button */
    padding: 10px 44px 10px 40px;
    font-size: 16px;
    border: 1px solid var(--border-primary);
    border-radius: 8px;
    outline: none;
    transition: border-color 0.15s ease;
  }

  .input-base:focus {
    border-color: #7f56d9;
    box-shadow: 0 0 0 4px rgba(158, 119, 237, 0.24);
  }

  /* Structural positions for icons */
  .input-icon-left {
    position: absolute;
    left: 14px;
    display: flex;
    align-items: center;
    color: var(--fg-quaternary);
    pointer-events: none;
  }

  /* Interactive Button Styling */
  .password-toggle-btn {
    position: absolute;
    right: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    color: var(--fg-quaternary);
    cursor: pointer;
    border-radius: 4px;
    outline: none;
  }

  .password-toggle-btn:focus-visible {
    box-shadow: 0 0 0 2px #7f56d9;
  }

  .password-toggle-btn:hover {
    color: #667085;
  }

  /* Set uniform dimensions across all nested SVGs */
  .input-icon-left :global(svg),
  .password-toggle-btn :global(svg),
  .hint-text :global(svg) {
    width: 16px;
    height: 16px;
    stroke-width: 2.25px;
  }

  /* Toggle Icons Visibility States */
  .icon-eye {
    display: inline-flex;
  }
  .icon-eye-off {
    display: none;
  }

  .password-toggle-btn.is-visible .icon-eye {
    display: none;
  }
  .password-toggle-btn.is-visible .icon-eye-off {
    display: inline-flex;
  }

  /* Hint Text Styling */
  .hint-text {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 14px;
    color: #475467;
  }

  .icon-success {
    display: inline-flex;
    color: var(--fg-quaternary);
    transition: color 0.1s linear;
  }

  .icon-error {
    display: none;
    color: var(--fg-error-secondary);
  }

  /* Field Validation States styling */
  .text-field.is-valid .icon-success {
    color: var(--fg-success-primary);
  }

  .text-field.is-invalid .icon-success {
    display: none;
  }

  .text-field.is-invalid .icon-error {
    display: inline-flex;
  }

  .text-field.is-invalid .hint-message {
    color: var(--fg-error-secondary);
  }
</style>
