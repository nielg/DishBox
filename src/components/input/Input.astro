---
interface Props {
  label: string;
  name: string;
  id?: string;
  type?: "text" | "number" | "tel" | "url" | "search";
  placeholder?: string;
  required?: boolean;
  hintText?: string;
}

const {
  label,
  name,
  id = name,
  type = "text",
  placeholder = "",
  required = false,
  hintText,
} = Astro.props;

import { AlertCircle, CheckCircle } from "@untitledui/icons";
---

<div class="text-field" data-required={required ? "true" : "false"}>
  <label for={id} class="label">
    {label}
    {
      required && (
        <span class="required" aria-hidden="true">
          *
        </span>
      )
    }
  </label>

  <div class="input-wrapper">
    {
      Astro.slots.has("icon") && (
        <div class="input-icon-left" aria-hidden="true">
          <slot name="icon" />
        </div>
      )
    }

    <input
      id={id}
      type={type}
      name={name}
      required={required}
      placeholder={placeholder}
      class:list={["input-base", { "has-icon": Astro.slots.has("icon") }]}
    />
  </div>

  {
    hintText && (
      <div class="hint-text">
        <span class="icon-success" aria-hidden="true">
          <CheckCircle />
        </span>
        <span class="icon-error" aria-hidden="true">
          <AlertCircle />
        </span>
        <span class="hint-message">{hintText}</span>
      </div>
    )
  }
</div>

<script>
  // Scoped inline script to initialize validation handlers on all general fields safely
  const containers = document.querySelectorAll(".text-field");

  containers.forEach((container) => {
    const input = container.querySelector(".input-base") as HTMLInputElement;
    const isRequired = container.getAttribute("data-required") === "true";

    if (!input) return;

    // Monitor input changes
    input.addEventListener("input", () => {
      if (input.value.trim().length > 0) {
        if (input.checkValidity()) {
          container.classList.add("is-valid");
          container.classList.remove("is-invalid");
        } else {
          container.classList.remove("is-valid");
        }
      } else {
        container.classList.remove("is-valid", "is-invalid");
      }
    });

    // Handle blur styling logic
    input.addEventListener("blur", () => {
      if (isRequired && !input.value.trim()) {
        container.classList.add("is-invalid");
        container.classList.remove("is-valid");
      } else if (!input.validity.valid) {
        container.classList.add("is-invalid");
        container.classList.remove("is-valid");
      }
    });
  });
</script>

<style>
  .text-field {
    --fg-quaternary: #98a2b3;
    --fg-success-primary: #079455;
    --fg-error-secondary: #d92d20;
    --border-primary: #d0d5dd;
    --text-primary: #101828;

    display: flex;
    flex-direction: column;
    gap: 6px;
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
  }

  .label {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
  }

  .required {
    color: var(--fg-error-secondary);
  }

  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input-base {
    width: 100%;
    padding: 10px 14px;
    font-size: 16px;
    border: 1px solid var(--border-primary);
    border-radius: 8px;
    outline: none;
    transition: border-color 0.15s ease;
  }

  /* Conditional padding applied on-the-fly if an icon is provided via slot */
  .input-base.has-icon {
    padding-left: 40px;
  }

  .input-base:focus {
    border-color: #7f56d9;
    box-shadow: 0 0 0 4px rgba(158, 119, 237, 0.24);
  }

  .input-icon-left {
    position: absolute;
    left: 14px;
    display: flex;
    align-items: center;
    color: var(--fg-quaternary);
    pointer-events: none;
  }

  /* Catches any UntitledUI component slotted in */
  .input-icon-left :global(svg),
  .hint-text :global(svg) {
    width: 16px;
    height: 16px;
    stroke-width: 2.25px;
  }

  .hint-text {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 14px;
    color: #475467;
  }

  .icon-success {
    display: inline-flex;
    color: var(--fg-quaternary);
    transition: color 0.1s linear;
  }

  .icon-error {
    display: none;
    color: var(--fg-error-secondary);
  }

  /* Validation rules state styles */
  .text-field.is-valid .icon-success {
    color: var(--fg-success-primary);
  }

  .text-field.is-invalid .icon-success {
    display: none;
  }

  .text-field.is-invalid .icon-error {
    display: inline-flex;
  }

  .text-field.is-invalid .hint-message {
    color: var(--fg-error-secondary);
  }
</style>
