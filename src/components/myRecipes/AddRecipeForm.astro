---
import InputPreview from "../input/InputPreview";
import InputTag from "../input/InputTag.astro";
---

<div class="form-container">
  <form id="add-recipe-form">
    <InputPreview
      client:load
      name="title"
      placeHolder="Recipe Title"
      type="h1"
    />

    <InputPreview
      client:load
      name="description"
      placeHolder="Detailed description of the recipe"
      type="textarea"
    />

    <div class="form-group">
      <div class="ingredients-header">
        <label for="ingredients">Ingredients for people</label>
        <input type="number" min="1" value="4" id="p_count" name="p_count" />
      </div>
    </div>
    <InputPreview
      client:load
      name="ingredients"
      placeHolder="Apple"
      type="ingredients"
    />

    <h3>Instuctions</h3>
    <InputPreview
      client:load
      name="description"
      placeHolder="Cut the apple in small pieces"
      type="instructions"
      number={1}
    />

    <InputTag name="tags" label="Tags" />

    <p>
      Make sure everything is correct and nothing is missing. Tip use markdown
      format for better styling
    </p>

    <button type="submit" class="submit-btn">Create Recipe</button>
  </form>
</div>

<style>
  .form-container {
    max-width: 600px;
    margin: 2rem auto;
    padding: 2rem;
    background-color: #fff;
    border: 2px solid rgb(61, 56, 56);
    border-radius: 0.5rem;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  h2 {
    margin-bottom: 1.5rem;
    text-align: center;
    color: #333;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: bold;
    color: #444;
  }

  input,
  textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #ccc;
    border-radius: 0.25rem;
    font-family: inherit;
    font-size: 1rem;
    box-sizing: border-box;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: rgb(61, 56, 56);
    box-shadow: 0 0 0 2px rgba(61, 56, 56, 0.1);
  }

  input[type="number"] {
    width: 5rem;
    height: 2rem;
    margin: 0.5rem;
  }

  small {
    display: block;
    margin-top: 0.25rem;
    color: #666;
    font-style: italic;
  }

  .ingredients-header {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
  }

  .submit-btn {
    display: block;
    width: 100%;
    padding: 1rem;
    background-color: var(--red-accent);
    color: white;
    border: none;
    border-radius: 0.25rem;
    font-size: 1.1rem;
    font-weight: bold;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .submit-btn:hover {
    background-color: rgb(40, 36, 36);
  }
</style>
<!-- TODO
Add validation in title for path traversel (../) -->
<script>
  const form = document.getElementById("add-recipe-form") as HTMLFormElement;

  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const rawData = Object.fromEntries(formData);

      const recipeRequest = {
        title: String(rawData.title),
        description: String(rawData.description),
        p_count: Number(rawData.p_count),
        ingredients: String(rawData.ingredients),
        instructions: String(rawData.instructions),
      };

      try {
        const response = await fetch("/api/recipesController", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(recipeRequest),
        });

        if (response.ok) {
          alert("Recipe created successfully!");
          window.location.href = `/myRecipes`;
        } else {
          const errorData = await response.json();
          alert(`Error: ${errorData.error || "Failed to create recipe"}`);
        }
      } catch (error) {
        console.error("Submission error:", error);
        alert("An error occurred while submitting the recipe.");
      }
    });
  }
</script>
