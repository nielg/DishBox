---
import "@/styles/auth.css";
import EmptyLayout from "@/layouts/EmptyLayout.astro";
import InputPassword from "@/components/input/InputPassword.astro";
import InputEmail from "@/components/input/InputEmail.astro";
import Input from "@/components/input/Input.astro";
---

<EmptyLayout>
  <div class="page-wrapper">
    <div class="container">
      <h2 class="text-center">Register</h2>
      <form action="submit">
        <InputEmail />
        <Input required label="Username" name="username" placeholder="you" />
        <InputPassword />
        <InputPassword />
        <button class="submit-btn" type="submit"> Register </button>
      </form>
      <a class="text-center" href="/user/auth/login"
        >Already have a account? <span class="border-bottom">Login</span></a
      >
    </div>
  </div>
</EmptyLayout>
