---
import "../../../../styles/auth.css";
import EmptyLayout from "../../../../layouts/EmptyLayout.astro";
---

<EmptyLayout>
  <div class="page-wrapper">
    <div class="container">
      <h2 class="text-center">Register</h2>
      <form action="submit">
        <div class="input-container">
          <label for="email">Email:</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="email@email.com"
            required
          />
        </div>
        <div class="input-container">
          <label for="username">Username:</label>
          <input
            type="text"
            id="username"
            name="username"
            placeholder="Username ..."
            required
          />
        </div>
        <div class="input-container">
          <label for="password">Password:</label>
          <input
            type="password"
            id="password"
            name="password"
            placeholder="Password"
            required
          />
        </div>
        <div class="input-container">
          <label for="conf-password">Password:</label>
          <input
            type="password"
            id="conf-password"
            placeholder="Confirm Password"
            required
          />
        </div>
        <button type="submit"> Register </button>
      </form>
      <a class="text-center" href="/user/auth/login"
        >Already have a account? <span class="border-bottom">Login</span></a
      >
    </div>
  </div>
</EmptyLayout>
